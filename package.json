{
  "name": "retailer",
  "version": "1.0.0",
  "main": "electron/main.js",
  "scripts": {
    "dev": "npm run kill:retailer-processes && concurrently -k \"npm:dev:server\" \"npm:dev:client\" \"npm:dev:electron\"",
    "dev:vendor": "node vendor-license-service/src/index.js",
    "dev:client": "npm run dev --prefix client -- --host 127.0.0.1 --port 5173 --strictPort",
    "dev:server": "npm run kill:retailer-processes && npm run electron:rebuild && npm run dev --prefix server",
    "dev:electron": "wait-on http://127.0.0.1:5173 tcp:5000 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "start": "npm run kill:retailer-processes && npm run electron:rebuild && npm run build --prefix client && electron .",
    "start:quick": "npm run build --prefix client && electron .",
    "build": "npm run build --prefix client",
    "dist": "npm run electron:rebuild && electron-builder --win",
    "windows:configure-users": "powershell -NoProfile -ExecutionPolicy Bypass -File ./electron/scripts/configure-local-users.ps1",
    "windows:harden-acl": "powershell -NoProfile -ExecutionPolicy Bypass -File ./electron/scripts/harden-windows-policy.ps1",
    "bootstrap": "npm install --workspaces",
    "kill:retailer-processes": "powershell -NoProfile -ExecutionPolicy Bypass -File ./electron/scripts/kill-retailer-processes.ps1",
    "node:rebuild": "npm rebuild better-sqlite3",
    "electron:rebuild": "electron-rebuild -f -w better-sqlite3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/M7mod-hegazy/Retailer.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/M7mod-hegazy/Retailer/issues"
  },
  "homepage": "https://github.com/M7mod-hegazy/Retailer#readme",
  "description": "",
  "dependencies": {
    "better-sqlite3": "^12.9.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^29.4.6",
    "electron-builder": "^26.8.1",
    "wait-on": "^9.0.5"
  },
  "private": true,
  "workspaces": [
    "client",
    "server"
  ]
}
